              "raw": "{\n  \"email\": \"super-admin@freecharge.test\",\n  \"password\": \"{{password_default}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('login ok', function(){ pm.expect(pm.response.code).to.eql(200); });",
            "const t = pm.response.json()?.data?.accessToken;",
            "pm.test('has token', function(){ pm.expect(t).to.be.a('string'); });",
            "pm.environment.set('token_super_admin', t);"
          ]}}]
