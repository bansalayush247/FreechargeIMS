    {
      "name": "00 - Setup",
      "item": [
        {
          "name": "Seed All (dev only)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/dev/seed/all",
              "host": ["{{baseUrl}}"],
              "path": ["dev", "seed", "all"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('seed ok', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "const json = pm.response.json();",
                  "pm.test('seed has data', function () { pm.expect(json && json.data).to.be.ok; });",
                  "const data = json.data || {};",
                  "const spaces = data.spaces || {};",
                  "const merchants = data.merchants || {};",
                  "const warehouses = data.warehouses || {};",
                  "const products = data.products || {};",
                  "const inventory = data.inventory || {};",
                  "const sampleRequests = data.sampleRequests || {};",
                  "",
                  "if (spaces.corporate && spaces.corporate._id) pm.environment.set('spaceId_corporate', spaces.corporate._id);",
                  "if (spaces.merchantOperations && spaces.merchantOperations._id) pm.environment.set('spaceId_merchant', spaces.merchantOperations._id);",
                  "if (merchants.sampleMerchant1 && merchants.sampleMerchant1._id) pm.environment.set('merchantId_sample1', merchants.sampleMerchant1._id);",
                  "if (warehouses.centralWarehouse && warehouses.centralWarehouse._id) pm.environment.set('warehouseId_corporate', warehouses.centralWarehouse._id);",
                  "if (warehouses.delhiWarehouse && warehouses.delhiWarehouse._id) pm.environment.set('warehouseId_merchant', warehouses.delhiWarehouse._id);",
                  "if (products.laptop && products.laptop._id) pm.environment.set('productId_seed_laptop', products.laptop._id);",
                  "if (inventory.laptop1 && inventory.laptop1._id) pm.environment.set('inventoryItemId_seed_laptop1', inventory.laptop1._id);",
                  "if (sampleRequests.employeeAssetRequest && sampleRequests.employeeAssetRequest._id) pm.environment.set('assetRequestId_seed_employee', sampleRequests.employeeAssetRequest._id);"
                ]
              }
            }
          ]
        },
